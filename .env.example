# Copy to .env and fill in all values. NEVER commit .env to version control.
# Node.js >= 18 required (built-in fetch).

# ── Discord OAuth (required) ──────────────────────────────────────────────────
#
# 1. Go to https://discord.com/developers/applications
# 2. Create a New Application
# 3. Under OAuth2 → General: copy Client ID and Client Secret
# 4. Under OAuth2 → Redirects: add your redirect URI exactly as set below
# 5. Under OAuth2 → Scopes: ensure "identify" and "guilds.members.read" are available
#    Note: guilds.members.read does NOT require bot verification for private/internal use.
#
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# The exact redirect URI you added in the Discord developer portal.
# For local dev: http://localhost:3000/auth/discord/callback
# For production: https://yourdomain.com/auth/discord/callback
DISCORD_REDIRECT_URI=http://localhost:3000/auth/discord/callback

# The Guild (server) ID users must be a member of.
# Right-click your server in Discord → Copy Server ID (Developer Mode must be on).
DISCORD_GUILD_ID=

# The Role ID users must hold to access the staff portal.
# Right-click the role in Server Settings → Roles → Copy Role ID.
DISCORD_REQUIRED_ROLE_ID=

# ── Session (required) ────────────────────────────────────────────────────────
# Long random string for signing session cookies. Generate with:
#   npm run secret
SESSION_SECRET=

# ── Optional ──────────────────────────────────────────────────────────────────
# HTTP port (default: 3000)
PORT=3000

# Set to "production" when behind nginx/HTTPS — enables secure cookies and
# trusts the X-Forwarded-For proxy header for rate limiting.
NODE_ENV=development

