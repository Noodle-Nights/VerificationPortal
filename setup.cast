[68.814725, "o", "\u001b[1;308H\u001b(B\u001b[0;7mModified\r\u001b[83d\u001b(B\u001b[m\u001b[K\u001b[1;316H"]
[68.816542, "o", "\r\u001b[2dEOF\r\u001b[4d\u001b[36m# ── Patch main sshd_config — override any explicit values set after the Include ──\r\u001b[5d# AlmaLinux 10 sets PermitRootLogin yes explicitly after the Include line;\r\u001b[6d# first-match-wins means it would override our drop-in.\r\u001b[7d\u001b(B\u001b[0;1m\u001b[34msed\u001b[35m -i\u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[33m's/^PermitRootLogin yes/PermitRootLogin prohibit-password/'\u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[33m\"$SSHD_CONFIG\"\r\u001b[8d\u001b[34msed\u001b[35m -i\u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[33m's/^PasswordAuthentication yes/PasswordAuthentication no/'\u001b[39m\u001b(B\u001b[m  \u001b(B\u001b[0;1m\u001b[33m\"$SSHD_CONFIG\"\r\u001b[10d\u001b(B\u001b[0m\u001b[36m# ── Disable conflicting drop-ins from other packages ─────────────────────────\r\u001b[11d# RHEL/AlmaLinux may ship drop-ins (e.g. 50-redhat.conf) that set\r\u001b[12d# PasswordAuthentication yes before our 99-hardened.conf is loaded.\r\u001b[13d"]
[68.816618, "o", "\u001b[32mfor\u001b[39m\u001b(B\u001b[m f \u001b[32min\u001b[39m\u001b(B\u001b[m /etc/ssh/sshd_config.d/*.conf\u001b[32m;\u001b[39m\u001b(B\u001b[m \u001b[32mdo\u001b[14;3H[[\u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[33m\"$f\"\u001b[39m\u001b(B\u001b[m \u001b[32m==\u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[33m\"$DROPIN\"\u001b[39m\u001b(B\u001b[m \u001b[32m]]\u001b[39m\u001b(B\u001b[m \u001b[32m&&\u001b[39m\u001b(B\u001b[m \u001b[32mcontinue\u001b[15;3Hif\u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[34mgrep\u001b[35m -q\u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[33m\"^PasswordAuthentication yes\"\u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[33m\"$f\"\u001b[39m\u001b(B\u001b[m 2\u001b[32m>\u001b[39m\u001b(B\u001b[m/dev/null\u001b[32m;\u001b[39m\u001b(B\u001b[m \u001b[32mthen\u001b[16;5H\u001b(B\u001b[0;1m\u001b[34msed\u001b[35m -i\u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[33m's/^PasswordAuthentication yes/PasswordAuthentication no/'\u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[33m\"$f\"\u001b[17;5H\u001b[34mecho\u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[33m\"Patched $f\"\u001b[18;3H\u001b(B\u001b[0m\u001b[32mfi\r\u001b[19ddone\r\u001b[21d\u001b(B\u001b[0;1m\u001b[34mecho\u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[33m\"Written $DROPIN\"\r\u001b[23d"]
[68.816979, "o", "\u001b(B\u001b[0m\u001b[36m# ── Validate & reload ─────────────────────────────────────────────────────────\r\u001b[24d\u001b(B\u001b[0;1m\u001b[34mecho\u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[33m\"Validating sshd config…\"\r\u001b[25d\u001b(B\u001b[0m\u001b[32mif\u001b[39m\u001b(B\u001b[m \u001b[32m!\u001b[39m\u001b(B\u001b[m sshd\u001b(B\u001b[0;1m\u001b[35m -t\u001b(B\u001b[0m\u001b[32m;\u001b[39m\u001b(B\u001b[m \u001b[32mthen\u001b[26;3H\u001b(B\u001b[0;1m\u001b[34mecho\u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[33m\"ERROR: sshd config validation failed. Reverting drop-in.\"\u001b[39m\u001b(B\u001b[m \u001b[32m>&\u001b[39m\u001b(B\u001b[m2\u001b[27;3H\u001b(B\u001b[0;1m\u001b[34mrm\u001b[35m -f\u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[33m\"$DROPIN\"\u001b[28;3H\u001b(B\u001b[0m\u001b[32mexit\u001b[39m\u001b(B\u001b[m 1\r\u001b[29d\u001b[32mfi\r\u001b[31d\u001b(B\u001b[0;1m\u001b[34mecho\u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[33m\"Restarting sshd…\"\r\u001b[32d\u001b[39m\u001b(B\u001b[msystemctl restart sshd\r\u001b[34d\u001b(B\u001b[0;1m\u001b[34mecho\u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[33m\"\"\r\u001b[35d\u001b[34mecho\u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[33m\"Done. SSH is hardened:\"\r\u001b[36d\u001b[34mecho\u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[33m\"  ✓ Root login: key-only (prohibit-password)\"\r\u001b[37d\u001b[34mecho\u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[33m\"  ✓ Password auth: disabled\"\r\u001b[38d\u001b[34mecho\u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[33m\"  ✓ Grace time: 20s, MaxAuthTries: 3\"\r\u001b[39d\u001b[34mecho\u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[33m\"  ✓ Weak KEX/ciphers/MACs: removed\"\r\u001b[40d\u001b[34mecho\u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[33m\"\"\r\u001b[41d\u001b[34mecho\u001b[39m\u001b(B\u001b[m \u001b(B\u001b[0;1m\u001b[33m\"Keep this session open and test login in a NEW terminal before closing.\"\r\u001b[42d\u001b[39m\u001b(B\u001b[m\u001b[?12l\u001b[?25h"]
