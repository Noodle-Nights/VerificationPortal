[146.496309, "o", "\u001b[1;308H\u001b(B\u001b[0;7mModified\r\u001b[83d\u001b(B\u001b[m\u001b[K\u001b[1;316H"]
[146.498896, "o", "\r\u001b[2d\u001b[36m# Copy to .env and fill in all values. NEVER commit .env to version control.\r\u001b[3d# Node.js >= 18 required (built-in fetch).\r\u001b[5d# ── Discord OAuth (required) ──────────────────────────────────────────────────\r\u001b[6d#\r\u001b[7d# 1. Go to https://discord.com/developers/applications\r\u001b[8d"]
[146.499585, "o", "# 2. Create a New Application\r\u001b[9d# 3. Under OAuth2 → General: copy Client ID and Client Secret\r\u001b[10d# 4. Under OAuth2 → Redirects: add your redirect URI exactly as set below\r\u001b[11d# 5. Under OAuth2 → Scopes: ensure \"identify\" and \"guilds.members.read\" are available\r\u001b[12d#    Note: guilds.members.read does NOT require bot verification for private/internal use.\r\u001b[13d#\r\u001b[14d\u001b[39m\u001b(B\u001b[mDISCORD_CLIENT_ID=REDACTED\r\u001b[15dDISCORD_CLIENT_SECRET=REDACTED\r\u001b[17d\u001b[36m# The exact redirect URI you added in the Discord developer portal.\r\u001b[18d# For local dev: http://localhost:3000/auth/discord/callback\r\u001b[19d# For production: https://yourdomain.com/auth/discord/callback\r\u001b[20d\u001b[39m\u001b(B\u001b[mDISCORD_REDIRECT_URI=http://localhost:3000/auth/discord/callback\r\u001b[21d\u001b[36m#DISCORD_REDIRECT_URI=https://verify.noodlenights.com/auth/discord/callback\r\u001b[23d# The Guild (server) ID users must be a member of.\r\u001b[24d# Right-click your server in Discord → Copy Server ID (Developer Mode must be on).\r\u001b[25d\u001b[39m\u001b(B\u001b[mDISCORD_GUILD_ID=REDACTED\r\u001b[27d\u001b[36m# The Role ID users must hold to access the staff portal.\r\u001b[28d# Right-click the role in Server Settings → Roles → Copy Role ID.\r\u001b[29d\u001b[39m\u001b(B\u001b[mDISCORD_REQUIRED_ROLE_ID=REDACTED\r\u001b[31d\u001b[36m# ── Session (required) ────────────────────────────────────────────────────────\r\u001b[32d# Long random string for signing session cookies. Generate with:\r\u001b[33d#   npm run secret\r\u001b[34d\u001b[39m\u001b(B\u001b[mSESSION_SECRET=REDACTED\r\u001b[36d\u001b[36m# ── Optional ──────────────────────────────────────────────────────────────────\r\u001b[37d# HTTP port (default: 3000)\r\u001b[38d\u001b[39m\u001b(B\u001b[mPORT=3000\r\u001b[40d\u001b[36m# Set to \"production\" when behind nginx/HTTPS — enables secure cookies and\r\u001b[41d# trusts the X-Forwarded-For proxy header for rate limiting.\r\u001b[42d\u001b[39m\u001b(B\u001b[mNODE_ENV=development\r\u001b[44d\u001b[?12l\u001b[?25h"]
