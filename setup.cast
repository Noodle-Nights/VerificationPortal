[145.831603, "o", "\r\u001b[84d\u001b(B\u001b[0;7m^G\u001b(B\u001b[m Help\u001b[84;19H\u001b(B\u001b[0;7m^O\u001b(B\u001b[m Write Out\u001b[37G\u001b(B\u001b[0;7m^F\u001b(B\u001b[m Where Is\u001b[55G\u001b(B\u001b[0;7m^K\u001b(B\u001b[m Cut\u001b[84;73H\u001b(B\u001b[0;7m^T\u001b(B\u001b[m Execute\u001b[84;91H\u001b(B\u001b[0;7m^C\u001b(B\u001b[m Location\u001b[109G\u001b(B\u001b[0;7mM-U\u001b(B\u001b[m Undo\u001b[84;127H\u001b(B\u001b[0;7mM-A\u001b(B\u001b[m Set Mark\t\u001b(B\u001b[0;7mM-]\u001b(B\u001b[m To Bracket    \u001b(B\u001b[0;7mM-B\u001b(B\u001b[m Previous\u001b[181G\u001b(B\u001b[0;7m◂\u001b(B\u001b[m Back\u001b[84;199H\u001b(B\u001b[0;7m^◂\u001b(B\u001b[m Prev Word\t\u001b(B\u001b[0;7m^A\u001b(B\u001b[m Home\u001b[84;235H\u001b(B\u001b[0;7m^P\u001b(B\u001b[m Prev Line\u001b[253G\u001b(B\u001b[0;7mM-▴\u001b(B\u001b[m Scroll Up     \u001b(B\u001b[0;7m^▴\u001b(B\u001b[m Prev Block     \u001b(B\u001b[0;7mM-(\u001b(B\u001b[m Begin of Paragr.\r\u001b[85d\u001b(B\u001b[0;7m^X\u001b(B\u001b[m Exit\u001b[85;19H\u001b(B\u001b[0;7m^R\u001b(B\u001b[m Read File\u001b[37G\u001b(B\u001b[0;7m^\\\u001b(B\u001b[m Replace\u001b[85;55H\u001b(B\u001b[0;7m^U\u001b(B\u001b[m Paste\u001b[85;73H\u001b(B\u001b[0;7m^J\u001b(B\u001b[m Justify\u001b[85;91H\u001b(B\u001b[0;7m^/\u001b(B\u001b[m Go To Line     \u001b(B\u001b[0;7mM-E\u001b(B\u001b[m Redo\u001b[85;127H\u001b(B\u001b[0;7mM-6\u001b(B\u001b[m Copy\u001b[85;145H\u001b(B\u001b[0;7m^B\u001b(B\u001b[m Where Was\t  \u001b(B\u001b[0;7mM-F\u001b(B\u001b[m Next\u001b[85;181H\u001b(B\u001b[0;7m▸\u001b(B\u001b[m Forward\u001b[85;199H\u001b(B\u001b[0;7m^▸\u001b(B\u001b[m Next Word\t\u001b(B\u001b[0;7m^E\u001b(B\u001b[m End\u001b[85;235H\u001b(B\u001b[0;7m^N\u001b(B\u001b[m Next Line\u001b[253G\u001b(B\u001b[0;7mM-▾\u001b(B\u001b[m Scroll Down   \u001b(B\u001b[0;7m^▾\u001b(B\u001b[m Next Block     \u001b(B\u001b[0;7mM-)\u001b(B\u001b[m End of Paragraph"]
